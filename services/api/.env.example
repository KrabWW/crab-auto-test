# Local dev environment for crab-api. Do not commit real secrets.
DATABASE_URL="postgresql://crab:crab@localhost:5432/crab?schema=public"

JWT_SECRET="dev-only-jwt-secret-change-me"
JWT_TTL_SECONDS="900"

WORKER_TOKEN_TTL_SECONDS="300"
WORKER_TOKEN_REFRESH_TTL_SECONDS="86400"

# Architect-R5 envelope encryption master key (base64, 32 bytes).
# Generate a real one for any non-local env:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
ENVELOPE_MASTER_KEY_B64="AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA="

PORT="3000"
HOST="0.0.0.0"

# Seed admin (pnpm db:seed)
SEED_ADMIN_EMAIL="admin@crab.local"
SEED_ADMIN_PASSWORD="admin12345"
